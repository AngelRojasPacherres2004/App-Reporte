<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppReporte">

        <activity
            android:name=".ui.general.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.general.LoadingActivity"
            android:exported="false" />
            
        <activity
            android:name=".ui.admin.SuperAdminDashboardActivity"
            android:exported="false"
            android:label="Panel Súper Administrador" />

        <activity
            android:name=".ui.general.DirectChatActivity"
            android:exported="false"
            android:label="Chat" />

        <activity
            android:name=".ui.padre.PadreDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.AdminDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.general.InicioActivity"
            android:exported="false" />

        <activity
            android:name=".ui.docente.DocenteDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.general.ForoSalonesActivity"
            android:exported="false" />

        <activity
            android:name=".ui.general.ForoDetalleActivity"
            android:exported="false" />

        <activity
            android:name=".ui.general.PostDetalleActivity"
            android:exported="false"
            android:label="Comentarios"
            android:theme="@style/Theme.AppReporte" />

        <!-- Pantalla del Chatbot con su nombre oficial -->
        <activity
            android:name=".ui.padre.ChatbotPadreActivity"
            android:exported="false"
            android:label="Asistente EduConnect" />

        <activity
            android:name=".ui.general.ForoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.padre.AsistenteActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.GestionAlumnosSalonesActivity"
            android:exported="false"
            android:label="Seleccionar Salón" />

        <activity
            android:name=".ui.docente.AlumnosListaActivity"
            android:exported="false"
            android:label="Lista de Alumnos" />

        <activity
            android:name=".ui.admin.GestionReportesSalonesActivity"
            android:exported="false"
            android:label="Reportes por Salón" />

        <activity
            android:name=".ui.docente.AlumnosReporteListaActivity"
            android:exported="false"
            android:label="Asignar Notas" />

        <activity
            android:name=".ui.general.PerfilActivity"
            android:exported="false"
            android:label="Mi Perfil" />

        <activity
            android:name=".ui.padre.PadreReporteActivity"
            android:exported="false"
            android:label="Mis Reportes" />

        <activity
            android:name=".ui.docente.ComplaintsActivity"
            android:exported="false"
            android:label="Gestión de Quejas" />

        <activity
            android:name=".ui.docente.DocenteHorarioActivity"
            android:exported="false"
            android:label="Mi Horario" />

        <activity
            android:name=".ui.docente.DocenteAsistenciaActivity"
            android:exported="false"
            android:label="Tomar Asistencia" />

        <activity
            android:name=".ui.padre.PadreHorarioActivity"
            android:exported="false"
            android:label="Horario del Alumno" />

        <activity
            android:name=".ui.padre.PadreAsistenciaActivity"
            android:exported="false"
            android:label="Historial de Asistencia" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>