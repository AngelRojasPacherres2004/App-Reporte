<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="?attr/selectableItemBackground">

    <FrameLayout
        android:id="@+id/flStaffAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_gradient_purple">
        <TextView
            android:id="@+id/tvStaffInitials"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="D"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_toEndOf="@id/flStaffAvatar"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStaffEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="docente@ejemplo.com"
            android:textColor="@color/on_surface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStaffRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Docente"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/bg_dot_green" />
</RelativeLayout>
